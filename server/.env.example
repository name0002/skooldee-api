# Copy to .env and fill in the values:
# cp .env.example .env

PORT=4000

# IMPORTANT: ใช้ secret ที่ random ยาว ≥ 32 ตัวใน production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES=7d

# SQLite path — บน Railway Volume ใช้: /data/data.sqlite
# DB_PATH=/data/data.sqlite

# LINE Messaging API (optional — ถ้าไม่ใส่ notify จะ simulate เท่านั้น)
# LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token

# CORS — domain ที่อนุญาตให้เรียก API (คั่นด้วย comma)
# ALLOWED_ORIGINS=https://skooldee.com,https://www.skooldee.com

# Platform super-admin — อีเมลที่เข้าถึงหน้า Platform Dashboard (ดูทุกโรงเรียน) ได้ คั่นด้วย comma
# PLATFORM_ADMIN_EMAILS=you@example.com

# AI Chat Assistant — Claude API key สำหรับ chatbot (landing FAQ + app help)
# ถ้าไม่ใส่ ทั้งสอง endpoint จะตอบ 503 (ไม่ crash ระบบหลัก)
# ANTHROPIC_API_KEY=sk-ant-...
