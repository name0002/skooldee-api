# SECURITY: hard-block any server/build paths. The build (scripts/build-pages.mjs)
# already excludes these from the deployment, so they don't physically exist — but
# these rules guarantee a 404 (instead of the SPA 200 fallback) even if something
# slips through. Keep them FIRST so they win over the rewrites below.
/server/*    /404.html  404
/scripts/*   /404.html  404

# /app and /app.html are both served by Cloudflare Pages clean-URL feature.
# Do NOT add a redirect for /app → /app.html here — it creates a redirect loop.

# Note: www → skooldee.com is handled in functions/_middleware.js,
# because Cloudflare Pages _redirects cannot match on hostname.

# "ต่อคอร์ส" link sent to parents via LINE: /<schoolSlug>/renew → renew landing page.
# 200 = rewrite (URL stays /<slug>/renew); destination is the CLEAN path /renew, not
# /renew.html — otherwise Cloudflare's .html clean-URL adds a 308 that drops the slug.
# renew.html reads the slug from the path (/<slug>/renew) since the URL is preserved.
/:slug/renew   /renew   200
/:slug/join    /enroll  200
